generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
}

enum ContentStatus {
  CONCEPT
  ACTIVE
  MAINTAINED
  ARCHIVED
}

enum MessageStatus {
  NEW
  REVIEWED
  REPLIED
  CLOSED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Project {
  id               String        @id @default(cuid())
  title            String
  slug             String        @unique
  shortDescription String
  fullDescription  String
  category         String
  status           ContentStatus @default(ACTIVE)
  image            String?
  gallery          String[]      @default([])
  techStack        String[]      @default([])
  liveUrl          String?
  githubUrl        String?
  featured         Boolean       @default(false)
  sortOrder        Int           @default(0)
  problemSolved    String?
  features         String[]      @default([])
  developmentNotes String?
  outcome          String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Plugin {
  id                String        @id @default(cuid())
  name              String
  slug              String        @unique
  tagline           String
  description       String
  version           String
  supportedVersions String[]      @default([])
  pluginType        String
  priceType         String
  price             Decimal?      @db.Decimal(10, 2)
  downloadUrl       String?
  spigotUrl         String?
  githubUrl         String?
  docsUrl           String?
  image             String?
  gallery           String[]      @default([])
  features          String[]      @default([])
  commands          Json          @default("[]")
  permissions       Json          @default("[]")
  dependencies      String[]      @default([])
  configExample     String?
  changelog         Json          @default("[]")
  featured          Boolean       @default(false)
  status            ContentStatus @default(ACTIVE)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model Skill {
  id          String @id @default(cuid())
  name        String
  category    String
  level       Int
  icon        String?
  description String
  sortOrder   Int    @default(0)
}

model Experience {
  id               String    @id @default(cuid())
  title            String
  organization     String
  type             String
  description      String
  startDate        DateTime
  endDate          DateTime?
  currentlyWorking Boolean   @default(false)
  logo             String?
}

model Service {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  description   String
  features      String[] @default([])
  icon          String?
  startingPrice String?
  active        Boolean  @default(true)
}

model Testimonial {
  id       String  @id @default(cuid())
  name     String
  role     String
  message  String
  avatar   String?
  rating   Int     @default(5)
  approved Boolean @default(false)
}

model BlogPost {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  excerpt    String
  content    String
  coverImage String?
  tags       String[] @default([])
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ContactMessage {
  id          String        @id @default(cuid())
  name        String
  email       String
  discord     String?
  subject     String
  projectType String?
  budgetRange String?
  message     String
  status      MessageStatus @default(NEW)
  createdAt   DateTime      @default(now())
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value Json
}
